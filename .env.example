# ==============================================
# TalentMatch - Environment Variables
# ==============================================
# Copy this file to .env and fill in all values

# ---- DATABASE ----
DATABASE_URL="postgresql://user:password@localhost:5432/talentmatch"

# ---- JWT AUTH ----
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# ---- ANTHROPIC AI ----
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ---- STRIPE PAYMENTS ----
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Product price IDs from your Stripe dashboard
STRIPE_PRICE_STANDARD="price_..."
STRIPE_PRICE_PREMIUM="price_..."

# ---- CLOUDINARY (Resume Storage) ----
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ---- SENDGRID EMAIL ----
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="noreply@talentmatch.io"
SENDGRID_FROM_NAME="TalentMatch"

# ---- SERVER ----
PORT=4000
NODE_ENV="production"
FRONTEND_URL="https://talentmatch.io"

# ---- FRONTEND (Next.js) ----
NEXT_PUBLIC_API_URL="https://api.talentmatch.io"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
